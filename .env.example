# Copy this file to .env and fill in your own values. Never commit .env.
# All values shown below are placeholders. Do not commit real credentials.

# --- Snowflake (optional) ------------------------------------------------
# Leave blank to fall back to the local CSV path (data/raw/*.csv).
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ACCOUNT=xy12345.us-east-1     # e.g. account locator
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=AIRLINE_LOYALTY_DB
SNOWFLAKE_SCHEMA=RAW_DATA

# --- AWS S3 (optional, only used by src/data_pipeline/s3_upload.py) ------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# --- Dashboard / API wiring --------------------------------------------
FASTAPI_URL=http://127.0.0.1:8000/predict
FASTAPI_HEALTH_URL=http://127.0.0.1:8000/health
FLASK_DEBUG=0
FLASK_PORT=5001
